{
    "name": "harrisrafto/laravel-aegis",
    "description": "Aegis for Laravel — scaffolding and validation helpers for Value Objects.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "value-object",
        "scaffolding",
        "validation",
        "form-request"
    ],
    "authors": [
        {
            "name": "Harris Raftopoulos",
            "email": "harrisrafto@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/console": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/filesystem": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/validation": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "HarrisRafto\\Aegis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HarrisRafto\\Aegis\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HarrisRafto\\Aegis\\AegisServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
